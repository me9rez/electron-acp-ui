{
  "compilerOptions": {
    "target": "ES2024",
    "lib": [
      "DOM",
      "ES2024"
    ],
    "module": "ESNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "electron",
  ]
}